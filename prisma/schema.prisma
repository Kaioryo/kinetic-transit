generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model bus_locations {
  id          Int       @id @default(autoincrement())
  trip_id     Int
  latitude    Decimal   @db.Decimal(10, 8)
  longitude   Decimal   @db.Decimal(11, 8)
  speed       Decimal?  @db.Decimal(5, 2)
  recorded_at DateTime? @default(now()) @db.Timestamp(0)
  trips       trips     @relation(fields: [trip_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_locations_trip")

  @@index([trip_id], map: "fk_locations_trip")
}

model buses {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(100)
  license_plate String    @unique(map: "license_plate") @db.VarChar(20)
  status        String?   @default("active") @db.VarChar(50)
  created_at    DateTime? @default(now()) @db.Timestamp(0)
  trips         trips[]
}

model etas {
  id                Int       @id @default(autoincrement())
  trip_id           Int
  stop_id           Int
  estimated_arrival DateTime  @db.Timestamp(0)
  calculated_at     DateTime? @default(now()) @db.Timestamp(0)
  stops             stops     @relation(fields: [stop_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_etas_stop")
  trips             trips     @relation(fields: [trip_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_etas_trip")

  @@unique([trip_id, stop_id], map: "trip_id")
  @@index([stop_id], map: "fk_etas_stop")
}

model route_stops {
  id         Int    @id @default(autoincrement())
  route_id   Int
  stop_id    Int
  stop_order Int
  routes     routes @relation(fields: [route_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_route_stops_route")
  stops      stops  @relation(fields: [stop_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_route_stops_stop")

  @@unique([route_id, stop_order], map: "route_id")
  @@index([stop_id], map: "fk_route_stops_stop")
}

model eta_logs {
  id                Int       @id @default(autoincrement())
  trip_id           Int
  stop_id           Int
  predicted_at      DateTime  @default(now()) @db.Timestamp(0) // kapan prediksi dibuat (saat bus berangkat dari halte sebelumnya)
  predicted_arrival DateTime  @db.Timestamp(0)                 // ETA absolut hasil prediksi
  actual_arrival    DateTime? @db.Timestamp(0)                 // diisi saat bus benar-benar tiba di halte
  error_seconds     Int?                                       // actual - predicted (detik); + = telat, - = lebih cepat

  @@index([trip_id, stop_id], map: "idx_eta_logs_trip_stop")
}

model routes {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(100)
  description String?       @db.Text
  waypoints   Json?         // Polyline jalan asli (array {lat,lng}) hasil OSRM — untuk ETA sepanjang rute
  created_at  DateTime?     @default(now()) @db.Timestamp(0)
  route_stops route_stops[]
  trips       trips[]
}

model stops {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(100)
  latitude    Decimal       @db.Decimal(10, 8)
  longitude   Decimal       @db.Decimal(11, 8)
  etas        etas[]
  route_stops route_stops[]
}

model trips {
  id            Int             @id @default(autoincrement())
  bus_id        Int
  route_id      Int
  status        String?         @default("scheduled") @db.VarChar(50)
  started_at    DateTime?       @db.Timestamp(0)
  ended_at      DateTime?       @db.Timestamp(0)
  bus_locations bus_locations[]
  etas          etas[]
  buses         buses           @relation(fields: [bus_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_trips_bus")
  routes        routes          @relation(fields: [route_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_trips_route")

  @@index([bus_id], map: "fk_trips_bus")
  @@index([route_id], map: "fk_trips_route")
}
